{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Folder }}",
  "description": "GitHub Dark - A GitHub-inspired Oh My Posh theme with rounded bubble segments. Uses GitHub's dark mode color palette. Requires a Nerd Font (CaskaydiaCove NF recommended).",
  "author": "Mark Orr",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "text",
          "style": "diamond",
          "foreground": "#f0f6fc",
          "background": "#21262d",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "template": " \ue70f "
        },
        {
          "type": "path",
          "style": "diamond",
          "foreground": "#f0f6fc",
          "background": "#1f6feb",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "template": " \uf07c {{ .Path }} ",
          "properties": {
            "style": "agnoster_short",
            "max_depth": 3
          }
        },
        {
          "type": "git",
          "style": "diamond",
          "foreground": "#f0f6fc",
          "background": "#6e40c9",
          "background_templates": [
            "{{ if or (gt .Ahead 0) (gt .Behind 0) }}#9e6a03{{ end }}",
            "{{ if .Working.Changed }}#da3633{{ end }}"
          ],
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4 ",
          "template": " \uf408 {{ .HEAD }} ",
          "properties": {
            "fetch_status": true,
            "fetch_stash_count": true
          }
        }
      ]
    },
    {
      "type": "rprompt",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "foreground": "#f0f6fc",
          "background": "#21262d",
          "leading_diamond": "\ue0b6",
          "trailing_diamond": "\ue0b4",
          "template": " {{ .CurrentDate | date \"3:04:05 PM\" }} "
        }
      ]
    }
  ]
}
